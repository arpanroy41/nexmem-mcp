# ── NexMem MCP Configuration ──────────────────────────────────────────

# Memory mode: "self" for personal memory, "team" for shared team memory
NEXMEM_MODE=self

# Your username (defaults to OS username if not set)
# NEXMEM_USER_NAME=alice

# Team name (required when NEXMEM_MODE=team)
# NEXMEM_TEAM_NAME=platform-eng

# Storage backend: jsonl | sqlite | mongodb | postgres | redis
NEXMEM_BACKEND=jsonl

# Read-only mode: set to "true" to disable all write tools
NEXMEM_READ_ONLY=false

# Custom instructions file or inline text (optional, defaults are built-in)
# NEXMEM_INSTRUCTIONS=./my-instructions.md

# ── Backend-specific configuration ─────────────────────────────────────

# JSONL (default)
# NEXMEM_JSONL_PATH=~/.nexmem/memory.jsonl

# SQLite
# NEXMEM_SQLITE_PATH=~/.nexmem/memory.db

# MongoDB
# NEXMEM_MONGODB_URI=mongodb://localhost:27017/nexmem

# PostgreSQL
# NEXMEM_POSTGRES_URI=postgresql://user:pass@localhost:5432/nexmem

# Redis
# NEXMEM_REDIS_URL=redis://localhost:6379/0
