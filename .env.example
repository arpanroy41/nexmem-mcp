# ── HiveMind MCP Configuration ──────────────────────────────────────────

# Memory mode: "self" for personal memory, "team" for shared team memory
HIVEMIND_MODE=self

# Your username (defaults to OS username if not set)
# HIVEMIND_USER_NAME=alice

# Team name (required when HIVEMIND_MODE=team)
# HIVEMIND_TEAM_NAME=platform-eng

# Storage backend: jsonl | sqlite | mongodb | postgres | redis
HIVEMIND_BACKEND=jsonl

# Read-only mode: set to "true" to disable all write tools
HIVEMIND_READ_ONLY=false

# Custom instructions file or inline text (optional, defaults are built-in)
# HIVEMIND_INSTRUCTIONS=./my-instructions.md

# ── Backend-specific configuration ─────────────────────────────────────

# JSONL (default)
# HIVEMIND_JSONL_PATH=~/.hivemind/memory.jsonl

# SQLite
# HIVEMIND_SQLITE_PATH=~/.hivemind/memory.db

# MongoDB
# HIVEMIND_MONGODB_URI=mongodb://localhost:27017/hivemind

# PostgreSQL
# HIVEMIND_POSTGRES_URI=postgresql://user:pass@localhost:5432/hivemind

# Redis
# HIVEMIND_REDIS_URL=redis://localhost:6379/0
